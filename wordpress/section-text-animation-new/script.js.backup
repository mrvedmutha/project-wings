/**
 * Detects visual line breaks in an element and logs each line's content.
 * Works by wrapping every word in a span, then grouping spans that share
 * the same offsetTop (i.e. same visual line).
 */
function getVisualLines(selector) {
  const el = document.querySelector(selector);
  if (!el) return console.warn(`Element "${selector}" not found.`);

  // Save original HTML so we can restore it later
  const originalHTML = el.innerHTML;

  // Get the full text (collapsed whitespace, trimmed)
  const fullText = el.textContent.replace(/\s+/g, " ").trim();
  const words = fullText.split(" ");

  // Wrap every word in an inline span
  el.innerHTML = words
    .map((word) => `<span class="__word">${word}</span>`)
    .join(" ");

  const spans = el.querySelectorAll(".__word");

  // Group words by their vertical position (offsetTop)
  const lines = [];
  let currentTop = null;
  let currentLine = [];

  spans.forEach((span) => {
    const top = span.offsetTop;
    if (currentTop === null || top === currentTop) {
      currentLine.push(span.textContent);
    } else {
      lines.push(currentLine.join(" "));
      currentLine = [span.textContent];
    }
    currentTop = top;
  });

  // Push the last line
  if (currentLine.length) lines.push(currentLine.join(" "));

  // Log results
  console.log(
    `%cTotal lines: ${lines.length}`,
    "color: #0af; font-weight: bold; font-size: 14px;",
  );
  lines.forEach((line, i) => {
    console.log(
      `%cLine ${i + 1} (${line.split(" ").length} words):`,
      "color: #f90; font-weight: bold;",
      line,
    );
  });

  // Rebuild DOM with line wrappers: .line (mask) > .line-inner (animates)
  el.innerHTML = lines
    .map(
      (lineText) =>
        `<span class="line"><span class="line-inner">${lineText}</span></span>`,
    )
    .join("");

  return lines;
}

function animateLines(selector) {
  const el = document.querySelector(selector);
  const lineInners = el.querySelectorAll(".line-inner");

  gsap.set(selector, { opacity: 1 });

  return gsap.from(lineInners, {
    duration: 0.6,
    yPercent: 100,
    opacity: 0,
    stagger: 0.25,
    ease: "expo.out",
  });
}

let resizeTimer;
let anim;

function init() {
  getVisualLines(".split");
  anim = animateLines(".split");
}

window.addEventListener("resize", () => {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(() => {
    if (anim) anim.kill();
    console.clear();
    console.log("%c--- Recalculated after resize ---", "color: #0f0;");
    getVisualLines(".split");
    anim = animateLines(".split");
  }, 400);
});

document.fonts.ready.then(init);
